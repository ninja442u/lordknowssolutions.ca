<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lordknows Solutions - Professional Painting Vancouver BC</title>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --navy: #001F3F;
            --white: #FFFFFF;
            --beige: #F5F5DC;
            --gray: #6C757D;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Open Sans', sans-serif; line-height: 1.6; color: var(--navy); }
        h1, h2, h3 { font-family: 'Montserrat', sans-serif; font-weight: 700; }
        .container { max-width: 1200px; margin: 0 auto; padding: 0 20px; }
        
        /* Hero */
        #hero { background: linear-gradient(rgba(0,31,63,0.8), rgba(0,31,63,0.8)), url('https://pplx-res.cloudinary.com/image/upload/pplx_search_images/37ec73e9cfe532caee2d94b502222ae0af1f4937.jpg') center/cover; height: 100vh; display: flex; align-items: center; justify-content: center; text-align: center; color: var(--white); }
        #hero h1 { font-size: 3.5rem; margin-bottom: 1rem; }
        #hero p { font-size: 1.5rem; margin-bottom: 2rem; }
        .cta { display: inline-block; background: var(--beige); color: var(--navy); padding: 1rem 2rem; margin: 0.5rem; text-decoration: none; font-weight: 600; border-radius: 5px; transition: transform 0.3s; }
        .cta:hover { transform: scale(1.05); }
        .phone-cta { background: transparent; border: 2px solid var(--beige); }
        
        /* Sections */
        section { padding: 80px 0; }
        .section-title { text-align: center; font-size: 2.5rem; margin-bottom: 3rem; color: var(--navy); }
        
        /* About */
        #about { background: var(--beige); }
        #about .content { text-align: center; max-width: 800px; margin: 0 auto; }
        #about p { font-size: 1.2rem; margin-bottom: 1rem; }
        
        /* Services */
        .services-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem; }
        .service { text-align: center; padding: 2rem; background: var(--white); border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
        .service i { font-size: 3rem; color: var(--beige); margin-bottom: 1rem; }
        
        /* Portfolio */
        .tabs { display: flex; justify-content: center; margin-bottom: 2rem; }
        .tab { padding: 1rem 2rem; background: var(--gray); color: var(--white); cursor: pointer; margin: 0 0.5rem; border-radius: 5px 5px 0 0; transition: background 0.3s; }
        .tab.active { background: var(--navy); }
        .gallery { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; }
        .gallery-item { position: relative; overflow: hidden; border-radius: 10px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
        .gallery-item img { width: 100%; height: 250px; object-fit: cover; transition: transform 0.3s; }
        .gallery-item:hover img { transform: scale(1.05); }
        .caption { position: absolute; bottom: 0; left: 0; right: 0; background: rgba(0,31,63,0.9); color: var(--white); padding: 1rem; }
        
        /* Why Choose */
        #why ul { list-style: none; max-width: 800px; margin: 0 auto; }
        #why li { display: flex; align-items: center; margin-bottom: 1.5rem; font-size: 1.2rem; }
        #why i { font-size: 2rem; color: var(--beige); margin-right: 1rem; width: 50px; }
        
        /* Contact */
        #contact { background: var(--navy); color: var(--white); }
        #contact h3 { margin-bottom: 1rem; }
        .contact-info { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; margin-bottom: 3rem; }
        .form-group { margin-bottom: 1rem; }
        .form-group label { display: block; margin-bottom: 0.5rem; }
        .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 1rem; border: none; border-radius: 5px; }
        .form-group button { background: var(--beige); color: var(--navy); padding: 1rem 2rem; border: none; border-radius: 5px; font-weight: 600; cursor: pointer; }
        #map { height: 300px; background: #ddd; border-radius: 10px; margin-top: 2rem; }
        
        /* Footer */
        footer { background: var(--navy); color: var(--white); padding: 2rem 0; text-align: center; }
        .footer-content { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; align-items: center; }
        .footer-links a { color: var(--beige); text-decoration: none; margin: 0 1rem; }
        
        /* Mobile */
        @media (max-width: 768px) {
            #hero h1 { font-size: 2.5rem; }
            #hero p { font-size: 1.2rem; }
            .tabs { flex-direction: column; align-items: center; }
        }
    </style>
</head>
<body>
